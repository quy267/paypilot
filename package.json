{
  "name": "paypilot",
  "version": "1.0.0",
  "private": true,
  "description": "PayPilot — AI assistant for triaging failed/flagged payment transactions (Cloudflare Workers + Agents + D1)",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "oxfmt --write .",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc",
    "eval": "tsx eval/run-eval.ts"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.8.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@streamdown/code": "^1.1.1",
    "agents": "^0.14.0",
    "ai": "^6.0.194",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@cloudflare/vite-plugin": "1.39.1",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "miniflare": "^4.20260529.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.105.0"
  }
}
